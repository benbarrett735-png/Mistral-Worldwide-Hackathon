# Mistral API key — get at console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Fine-tuned model endpoints (HuggingFace + Colab GPU + ngrok)
# Flystral: run flystral/serve_colab.ipynb → BenBarr/flystral
FLYSTRAL_ENDPOINT=
# Helpstral: run helpstral/serve_colab.ipynb → BenBarr/helpstral
HELPSTRAL_ENDPOINT=

# ArduPilot: leave unset to use SITL simulator. Set for real drone hardware.
# Examples:
#   MAV_CONNECTION=tcp:192.168.1.10:5760        # WiFi telemetry (TCP)
#   MAV_CONNECTION=udp:0.0.0.0:14550            # MAVProxy/QGC UDP
#   MAV_CONNECTION=serial:/dev/ttyUSB0:57600     # USB telemetry radio
#   MAV_CONNECTION=serial:/dev/tty.usbserial:57600  # macOS USB serial
# MAV_CONNECTION=

# Real hardware: set ARMING_CHECK=1 to enable ArduPilot safety checks. Default 0 for SITL.
# ARMING_CHECK=1

# City hub — paris | dublin | london | kilcoole
# DEFAULT_CITY=kilcoole

# Routing
ORS_API_KEY=your_openrouteservice_api_key_here

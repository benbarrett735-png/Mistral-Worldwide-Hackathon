# Required for Helpstral (distress) and Flystral (obstacle/path) — get key at console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Vision model for image analysis (Helpstral/Flystral). Default: pixtral-12b-2409
# MISTRAL_VISION_MODEL=pixtral-12b-2409
# General text model for path/decisions. Default: mistral-large-latest
# MISTRAL_GENERAL_MODEL=mistral-large-latest

# Override per-endpoint (optional); if unset, uses MISTRAL_VISION_MODEL
# HELPSTRAL_MODEL_ID=
# FLYSTRAL_MODEL_ID=

# ArduPilot: leave unset to use SITL (server will start SITL if needed). Set for real drone.
# Examples: tcp:192.168.1.10:5760  or  serial:/dev/ttyUSB0:57600
# When set, server does NOT start SITL or wait for EKF.
# MAV_CONNECTION=

# SITL (only used when MAV_CONNECTION is not set)
# SITL_HOST=127.0.0.1
# SITL_PORT=5760

PEXELS_API_KEY=your_pexels_api_key_here
ORS_API_KEY=your_openrouteservice_api_key_here
